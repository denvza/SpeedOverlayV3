<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Speed Overlay V3"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OSM speed limits + TomTom flow"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <!-- TomTom API Key (optional) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TomTom API Key (Optional)"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter TomTom API key (not required)"
                android:textColorHint="#444444"
                android:textColor="#FFFFFF"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:fontFamily="monospace"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnShowHideKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#2a2a2a"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Without API key: shows OSM speed limit only\nWith API key: shows OSM/TomTom e.g. 50/52"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#222222" android:layout_marginBottom="20dp" />

        <!-- OSM Cache -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OSM Cache (7 days)"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvOsmCacheInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OSM cached segments: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnClearOsm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:backgroundTint="#2a2a2a"
                android:textColor="#FF6B6B"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- TomTom Cache -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TomTom Cache (7 days)"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvTomTomCacheInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TomTom cached segments: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnClearTomTom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:backgroundTint="#2a2a2a"
                android:textColor="#FF6B6B"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TomTom API key is optional. OSM works without it."
            android:textColor="#777777"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Overlay"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Info box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/info_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What's new in V3"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• OSM speed limits cached for 7 days\n• TomTom API key is now optional\n• Purple dot when no OSM data available\n• Auto-corrects OSM vs TomTom divergence &gt;15 km/h\n• Separate cache clear buttons"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
